# Resend API key for contact form submissions
# Get yours at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Analytics 4 Measurement ID (optional). When unset, no analytics
# loads. Create a GA4 property at https://analytics.google.com and paste the
# "G-XXXXXXXXXX" ID here (and in your Vercel project's Environment Variables).
# See SEO-SETUP.md for the full setup + Search Console steps.
VITE_GA_ID=
